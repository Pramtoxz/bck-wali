{
  "info": {
    "name": "SIWALI API - Wali Nagari Digital Attendance",
    "description": "API Collection untuk testing backend SIWALI",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000/api",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.collectionVariables.set('token', jsonData.data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"username\": \"admin\",\n    \"password\": \"admin123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Get User",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/user",
              "host": ["{{base_url}}"],
              "path": ["auth", "user"]
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/logout",
              "host": ["{{base_url}}"],
              "path": ["auth", "logout"]
            }
          }
        }
      ]
    },
    {
      "name": "Field Duty",
      "item": [
        {
          "name": "Get Field Duty List",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/field-duty?limit=3",
              "host": ["{{base_url}}"],
              "path": ["field-duty"],
              "query": [
                {
                  "key": "limit",
                  "value": "3"
                }
              ]
            }
          }
        },
        {
          "name": "Submit Field Duty",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "start_date",
                  "value": "2026-04-20",
                  "type": "text"
                },
                {
                  "key": "end_date",
                  "value": "2026-04-22",
                  "type": "text"
                },
                {
                  "key": "destination",
                  "value": "Padang",
                  "type": "text"
                },
                {
                  "key": "purpose",
                  "value": "Rapat koordinasi dengan Pemda Sumatera Barat",
                  "type": "text"
                },
                {
                  "key": "document",
                  "type": "file",
                  "src": []
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/field-duty",
              "host": ["{{base_url}}"],
              "path": ["field-duty"]
            }
          }
        }
      ]
    },
    {
      "name": "Leave",
      "item": [
        {
          "name": "Get Leave List",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/leave?limit=3",
              "host": ["{{base_url}}"],
              "path": ["leave"],
              "query": [
                {
                  "key": "limit",
                  "value": "3"
                }
              ]
            }
          }
        },
        {
          "name": "Submit Leave (with document)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "start_date",
                  "value": "2026-04-18",
                  "type": "text"
                },
                {
                  "key": "end_date",
                  "value": "2026-04-19",
                  "type": "text"
                },
                {
                  "key": "type",
                  "value": "sakit",
                  "type": "text"
                },
                {
                  "key": "reason",
                  "value": "Demam tinggi dan perlu istirahat",
                  "type": "text"
                },
                {
                  "key": "document",
                  "type": "file",
                  "src": []
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/leave",
              "host": ["{{base_url}}"],
              "path": ["leave"]
            }
          }
        },
        {
          "name": "Submit Leave (without document)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "start_date",
                  "value": "2026-04-25",
                  "type": "text"
                },
                {
                  "key": "end_date",
                  "value": "2026-04-25",
                  "type": "text"
                },
                {
                  "key": "type",
                  "value": "izin",
                  "type": "text"
                },
                {
                  "key": "reason",
                  "value": "Keperluan keluarga",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/leave",
              "host": ["{{base_url}}"],
              "path": ["leave"]
            }
          }
        }
      ]
    }
  ]
}
